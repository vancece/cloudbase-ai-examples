{
  "$schema": "https://codesandbox.io/docs/projects/schema/tasks.json",
  "setupTasks": [
    {
      "name": "Install Dependencies",
      "command": "cd multi-turn && npm install && cd ../streaming && npm install && cd ../deep-thinking && npm install && cd ../context-caching && npm install && cd ../tool-calling && npm install && cd ../nodejs-sdk && npm install && cd ../openai-sdk && npm install && cd ../anthropic-sdk && npm install"
    }
